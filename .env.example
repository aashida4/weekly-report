# SQLite database file (Docker: /data/app.db, local dev: prisma/dev.db)
DATABASE_URL="file:./prisma/dev.db"

# Auth.js: generate with `openssl rand -base64 32`
AUTH_SECRET="change-me-to-a-random-32-byte-string"
AUTH_TRUST_HOST="true"

# Ollama remote server (lab server) — overwrite to your endpoint
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# Allow open signup ("true" or "false"). When false, only admin can create users.
ALLOW_SIGNUP="true"
