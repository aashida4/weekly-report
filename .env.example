# SQLite database file (Docker: /data/app.db, local dev: prisma/dev.db)
DATABASE_URL="file:./prisma/dev.db"

# Auth.js: generate with `openssl rand -base64 32`
AUTH_SECRET="change-me-to-a-random-32-byte-string"
AUTH_TRUST_HOST="true"

# Which LLM backend to use for feedback generation.
#   "ollama" (default): self-hosted, uses OLLAMA_BASE_URL and OLLAMA_MODEL below.
#   "openai": OpenAI Chat Completions API, uses OPENAI_* below.
LLM_PROVIDER="ollama"

# --- Ollama (used when LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# --- OpenAI (used when LLM_PROVIDER=openai) ---
# Required when LLM_PROVIDER=openai. Set via your secret manager in production.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Optional: point at an Azure OpenAI / compatible endpoint. Default: https://api.openai.com/v1
# OPENAI_BASE_URL=""

# Allow open signup ("true" or "false"). When false, only admin can create users.
ALLOW_SIGNUP="true"
